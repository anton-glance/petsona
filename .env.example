# Public env vars exposed to the Expo client at build time.
# Only EXPO_PUBLIC_* vars are inlined into the client bundle.
# Never put service_role keys here.
#
# Copy this file to .env.local and fill with values from
# https://supabase.com/dashboard/project/hkhzukxmonlgzzmuqvvp/settings/api
#
# Note: the "publishable key" format (sb_publishable_...) goes in the
# ANON_KEY slot --- the env var name is legacy, the key format is new.
# Both formats work with supabase-js identically.
#
# For EAS Build to pick these up at native build time:
#   eas env:create --environment development --name EXPO_PUBLIC_SUPABASE_URL --value <url>
#   eas env:create --environment development --name EXPO_PUBLIC_SUPABASE_ANON_KEY --value <key>

EXPO_PUBLIC_SUPABASE_URL=https://hkhzukxmonlgzzmuqvvp.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=replace-with-publishable-key-from-dashboard

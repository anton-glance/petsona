{
  "expo": {
    "name": "Petsona",
    "slug": "petsona",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "petsona",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/brand/app-icon-1024.png",
    "ios": {
      "bundleIdentifier": "com.antonglance.petsona",
      "supportsTablet": true,
      "icon": "./assets/brand/app-icon-1024.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.antonglance.petsona",
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/android-adaptive-foreground-1024.png",
        "backgroundImage": "./assets/brand/android-adaptive-background-1024.png",
        "monochromeImage": "./assets/brand/android-monochrome-432.png",
        "backgroundColor": "#2D4F3C"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/brand/favicon.svg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FBF7EE",
          "image": "./assets/brand/splash-1024.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#15130E",
            "image": "./assets/brand/splash-dark-1024.png"
          }
        }
      ],
      "expo-localization",
      [
        "@sentry/react-native/expo",
        {
          "organization": "exicore",
          "project": "petsona-mobile"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Petsona uses your camera to identify your pet's breed and digitize their records.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Petsona accesses your photos so you can pick an existing photo of your pet."
        }
      ],
      "expo-build-properties"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a268d3f9-4f46-4f36-b9ab-46c9ca6e7f3b"
      }
    },
    "owner": "anton-glance"
  }
}

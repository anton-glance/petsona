{
  "expo": {
    "name": "MyPet",
    "slug": "mypet",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "mypet",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.antonglance.mypet",
      "supportsTablet": true
    },
    "android": {
      "package": "com.antonglance.mypet",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

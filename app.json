{
  "expo": {
    "name": "Petsona",
    "slug": "petsona",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "petsona",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.antonglance.petsona",
      "supportsTablet": true
    },
    "android": {
      "package": "com.antonglance.petsona",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a268d3f9-4f46-4f36-b9ab-46c9ca6e7f3b"
      }
    },
    "owner": "anton-glance"
  }
}
